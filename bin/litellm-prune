#!/usr/bin/env bash
# litellm-prune — Remove unnecessary upstream files from the litellm submodule
# Run after syncing with upstream, or automatically via the post-merge hook.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LITELLM_DIR="$(cd "$SCRIPT_DIR/../litellm" && pwd)"

# Directories to remove (relative to litellm submodule root)
PRUNE_DIRS=(
    docs
    tests
    ui
    enterprise
    cookbook
    litellm-proxy-extras
    litellm-js
    .circleci
    .github
    .semgrep
    .devcontainer
    ci_cd
    db_scripts
    deploy
    docker
    dist
    scripts
)

# Files to remove (relative to litellm submodule root)
#
# KEEP these — they are needed at runtime or by `pip install -e .`:
#   pyproject.toml, requirements.txt, schema.prisma, LICENSE,
#   proxy_server_config.yaml, model_prices_and_context_window.json,
#   policy_templates.json, provider_endpoints_support.json
# KEEP also (helpful context for Claude / agents working in the submodule):
#   AGENTS.md, ARCHITECTURE.md, CLAUDE.md
PRUNE_FILES=(
    # Docs / project meta
    # NOTE: README.md is referenced by pyproject.toml (`readme = "README.md"`)
    # and pip's editable build fails without it — keep.
    CONTRIBUTING.md
    GEMINI.md
    security.md
    # CI / lint / typing configs
    .dockerignore
    .flake8
    .git-blame-ignore-revs
    .gitattributes
    .gitguardian.yaml
    .npmrc
    .pre-commit-config.yaml
    .trivyignore
    codecov.yaml
    pyrightconfig.json
    ruff.toml
    taplo.toml
    # Build / deploy configs we don't use
    Dockerfile
    Makefile
    cosign.pub
    dev_config.yaml
    docker-compose.hardened.yml
    docker-compose.yml
    index.yaml
    license_cache.json
    mcp_servers.json
    prometheus.yml
    render.yaml
    # JS leftovers (litellm-js dir already pruned above)
    package-lock.json
    package.json
    # Lockfiles for build tools we don't use (pyproject.toml drives pip)
    poetry.lock
    uv.lock
)

bytes_before=$(du -sb "$LITELLM_DIR" 2>/dev/null | cut -f1 || du -sk "$LITELLM_DIR" | awk '{print $1*1024}')

removed=0
for dir in "${PRUNE_DIRS[@]}"; do
    target="$LITELLM_DIR/$dir"
    if [[ -d "$target" ]]; then
        rm -rf "$target"
        ((removed++))
    fi
done

for file in "${PRUNE_FILES[@]}"; do
    target="$LITELLM_DIR/$file"
    if [[ -f "$target" ]]; then
        rm -f "$target"
        ((removed++))
    fi
done

bytes_after=$(du -sb "$LITELLM_DIR" 2>/dev/null | cut -f1 || du -sk "$LITELLM_DIR" | awk '{print $1*1024}')
saved=$(( (bytes_before - bytes_after) / 1048576 ))

if [[ "$removed" -gt 0 ]]; then
    echo "litellm-prune: removed $removed items, freed ~${saved}MB"
else
    echo "litellm-prune: nothing to prune"
fi
