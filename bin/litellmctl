#!/usr/bin/env bash
#
# litellmctl — Thin shim that activates the venv and execs into Python.
#
# Tab completion support:
#   litellmctl --completions       (bash)
#   litellmctl --zsh-completions   (zsh)
#
set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_ROOT="$(cd "$BIN_DIR/.." && pwd)"

# User data dir: explicit override (e.g. Docker volume), else same rules as lib.common.paths
if [ -n "${LITELLMCTL_HOME:-}" ]; then
  PROJECT_DIR="$LITELLMCTL_HOME"
elif [ -f "$INSTALL_ROOT/config.yaml" ]; then
  PROJECT_DIR="$INSTALL_ROOT"
else
  PROJECT_DIR="$HOME/.litellm"
fi

VENV_DIR="$INSTALL_ROOT/venv"

# Activate venv if it exists
if [ -d "$VENV_DIR" ]; then
  export VIRTUAL_ENV="$VENV_DIR"
  export PATH="$VENV_DIR/bin:$PATH"
fi

export PYTHONPATH="$BIN_DIR${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m lib "$@"
