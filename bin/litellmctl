#!/usr/bin/env bash
#
# litellmctl — LiteLLM proxy control CLI.
#
# Usage:
#   litellmctl <command> [args...]
#   litellmctl install              Install, update, or rebuild LiteLLM
#   litellmctl auth status          Show auth token status
#   litellmctl start                Start proxy as background service
#   litellmctl stop                 Stop the proxy service
#   litellmctl restart | r          Restart the proxy service
#   litellmctl logs                 Tail proxy logs
#   litellmctl proxy                Start proxy in foreground (debug)
#   litellmctl help                 Show this help
#
# Tab completion:
#   litellmctl setup-completions
#

set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$BIN_DIR/.." && pwd)"

# If running from a symlink outside ~/.litellm, resolve to canonical path
if [ ! -f "$PROJECT_DIR/config.yaml" ]; then
  PROJECT_DIR="$HOME/.litellm"
fi
VENV_DIR="$PROJECT_DIR/venv"
PORT_FILE="$PROJECT_DIR/.proxy-port"
LOG_DIR="$PROJECT_DIR/logs"

# Service identifiers
LAUNCHD_LABEL="com.litellm.proxy"
LAUNCHD_PLIST="$HOME/Library/LaunchAgents/${LAUNCHD_LABEL}.plist"
SYSTEMD_UNIT="litellm-proxy"
SYSTEMD_DIR="$HOME/.config/systemd/user"
SYSTEMD_FILE="$SYSTEMD_DIR/${SYSTEMD_UNIT}.service"

# ── Completions ─────────────────────────────────────────────────────────────

generate_completions() {
  cat <<'COMP'
_litellmctl_completions() {
  local cur prev commands auth_cmds
  COMPREPLY=()
  cur="${COMP_WORDS[COMP_CWORD]}"
  prev="${COMP_WORDS[COMP_CWORD-1]}"

  commands="auth wizard install init-env start stop restart r logs proxy status toggle-claude setup-completions help"
  auth_cmds="chatgpt gemini qwen kimi codex status refresh export import"

  case "$prev" in
    litellmctl)
      COMPREPLY=( $(compgen -W "$commands" -- "$cur") )
      return ;;
    auth)
      COMPREPLY=( $(compgen -W "$auth_cmds" -- "$cur") )
      return ;;
    refresh|export)
      COMPREPLY=( $(compgen -W "chatgpt gemini qwen kimi" -- "$cur") )
      return ;;
    start|proxy)
      COMPREPLY=( $(compgen -W "--port --config" -- "$cur") )
      return ;;
    install)
      COMPREPLY=( $(compgen -W "--with-db --without-db" -- "$cur") )
      return ;;
  esac
}
complete -F _litellmctl_completions litellmctl
COMP
}

generate_zsh_completions() {
  cat <<'COMP'
_litellmctl_completions() {
  local -a commands auth_cmds
  commands=(
    'auth:Manage OAuth tokens'
    'wizard:Interactive config.yaml generator'
    'install:Install, update, or rebuild LiteLLM (prompts for DB setup)'
    'init-env:Detect auth files and update .env paths'
    'start:Start proxy as background service'
    'stop:Stop the proxy service'
    'restart:Restart the proxy service'
    'r:Alias for restart'
    'logs:Tail proxy logs'
    'proxy:Start proxy in foreground (debug)'
    'status:Show auth + proxy status'
    'toggle-claude:Toggle Claude Code between direct API and proxy'
    'setup-completions:Add litellmctl to your shell'
    'help:Show help'
  )
  auth_cmds=(
    'chatgpt:Login to ChatGPT/Codex'
    'gemini:Login to Gemini CLI'
    'qwen:Login to Qwen Portal'
    'kimi:Login to Kimi Code'
    'codex:Login to ChatGPT/Codex'
    'status:Show token status'
    'refresh:Refresh existing token'
    'export:Copy credentials as transfer script'
    'import:Read credentials from stdin'
  )

  if (( CURRENT == 2 )); then
    _describe 'command' commands
  elif (( CURRENT == 3 )); then
    case "${words[2]}" in
      auth)    _describe 'auth command' auth_cmds ;;
      refresh|export) compadd chatgpt gemini qwen kimi ;;
      start|proxy) compadd -- --port --config ;;
      install) compadd -- --with-db --without-db ;;
    esac
  elif (( CURRENT == 4 )); then
    case "${words[3]}" in
      refresh|export) compadd chatgpt gemini qwen kimi ;;
    esac
  fi
}
compdef _litellmctl_completions litellmctl
COMP
}

# ── Helpers ─────────────────────────────────────────────────────────────────

info()  { printf "\033[1;34m==> %s\033[0m\n" "$*"; }
warn()  { printf "\033[1;33m==> %s\033[0m\n" "$*"; }
error() { printf "\033[1;31m==> %s\033[0m\n" "$*" >&2; }

activate_venv() {
  if [ ! -d "$VENV_DIR" ]; then
    error "No virtualenv found. Run 'litellmctl install' first."
    exit 1
  fi
  # shellcheck disable=SC1091
  source "$VENV_DIR/bin/activate"
}

load_env() {
  if [ -f "$PROJECT_DIR/.env" ]; then
    set -a
    # shellcheck disable=SC1091
    source "$PROJECT_DIR/.env"
    set +a
  fi
}

get_proxy_port() {
  if [ -f "$PORT_FILE" ]; then
    cat "$PORT_FILE"
  else
    echo "4040"
  fi
}

is_interactive() { [ -t 0 ]; }

# Portable PID lookup for a listening port — works on Linux without lsof.
_pids_on_port() {
  local port="$1"
  if command -v lsof &>/dev/null; then
    lsof -i :"$port" -t 2>/dev/null || true
  elif command -v ss &>/dev/null; then
    ss -tlnp "sport = :$port" 2>/dev/null \
      | grep -oP 'pid=\K[0-9]+' 2>/dev/null || true
  elif command -v fuser &>/dev/null; then
    fuser "$port/tcp" 2>/dev/null | tr -s ' ' '\n' | grep -E '^[0-9]+$' || true
  fi
}

_is_litellm_pid() {
  local pid="$1"
  local cmd
  cmd=$(ps -p "$pid" -o command= 2>/dev/null) || return 1
  [[ "$cmd" == *litellm* ]]
}

# Return only LiteLLM PIDs listening on the given port.
_litellm_pids_on_port() {
  local port="$1"
  local pids pid
  pids=$(_pids_on_port "$port")
  for pid in $pids; do
    if _is_litellm_pid "$pid"; then
      echo "$pid"
    fi
  done
}

find_proxy_pid() {
  local port pid
  port=$(get_proxy_port)
  while IFS= read -r pid; do
    [ -n "$pid" ] && { echo "$pid"; return 0; }
  done < <(_litellm_pids_on_port "$port")
  return 0
}

kill_stale_on_port() {
  local port="$1"
  local pids
  pids=$(_litellm_pids_on_port "$port")
  if [ -n "$pids" ]; then
    local count
    count=$(echo "$pids" | wc -l | tr -d ' ')
    warn "Killing $count stale litellm process(es) on port $port: $(echo $pids | tr '\n' ' ')"
    echo "$pids" | xargs kill -9 2>/dev/null || true
    sleep 1
  fi
}

is_macos() { [[ "$(uname -s)" == "Darwin" ]]; }
is_linux() { [[ "$(uname -s)" == "Linux" ]]; }

_run_with_sudo_if_needed() {
  # Tries non-interactive sudo first, then interactive sudo when possible.
  # Usage: _run_with_sudo_if_needed <cmd> [args...]
  if [ "$EUID" -eq 0 ]; then
    "$@"
    return $?
  fi
  command -v sudo &>/dev/null || return 1
  sudo -n "$@" 2>/dev/null && return 0
  if is_interactive; then
    sudo "$@"
    return $?
  fi
  return 1
}

# Build extra CLI flags from env vars (NUM_WORKERS, KEEPALIVE_TIMEOUT).
_perf_flags() {
  local flags=()
  local workers="${NUM_WORKERS:-1}"
  if [ "$workers" -gt 1 ] 2>/dev/null; then
    flags+=(--num_workers "$workers")
  fi
  if [ -n "${KEEPALIVE_TIMEOUT:-}" ]; then
    flags+=(--keepalive_timeout "$KEEPALIVE_TIMEOUT")
  fi
  echo "${flags[@]}"
}

ensure_log_dir() {
  mkdir -p "$LOG_DIR"
}

# ── Service: macOS launchd ──────────────────────────────────────────────────

launchd_install() {
  local port="$1"
  local config="$2"

  ensure_log_dir
  mkdir -p "$(dirname "$LAUNCHD_PLIST")"

  local env_block=""
  if [ -f "$PROJECT_DIR/.env" ]; then
    while IFS='=' read -r key value; do
      [[ "$key" =~ ^[[:space:]]*# ]] && continue
      [[ -z "$key" ]] && continue
      env_block="${env_block}    <key>${key}</key>
    <string>${value}</string>
"
    done < "$PROJECT_DIR/.env"
  fi

  local perf_args=""
  local workers="${NUM_WORKERS:-1}"
  if [ "$workers" -gt 1 ] 2>/dev/null; then
    perf_args="${perf_args}    <string>--num_workers</string>
    <string>${workers}</string>
"
  fi
  if [ -n "${KEEPALIVE_TIMEOUT:-}" ]; then
    perf_args="${perf_args}    <string>--keepalive_timeout</string>
    <string>${KEEPALIVE_TIMEOUT}</string>
"
  fi

  cat > "$LAUNCHD_PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LAUNCHD_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${VENV_DIR}/bin/litellm</string>
    <string>--config</string>
    <string>${config}</string>
    <string>--port</string>
    <string>${port}</string>
${perf_args}  </array>
  <key>WorkingDirectory</key>
  <string>${PROJECT_DIR}</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>${VENV_DIR}/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>VIRTUAL_ENV</key>
    <string>${VENV_DIR}</string>
${env_block}  </dict>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${LOG_DIR}/proxy.log</string>
  <key>StandardErrorPath</key>
  <string>${LOG_DIR}/proxy-error.log</string>
</dict>
</plist>
PLIST

  echo "$port" > "$PORT_FILE"

  launchctl bootout "gui/$(id -u)/${LAUNCHD_LABEL}" 2>/dev/null || true
  if ! launchctl bootstrap "gui/$(id -u)" "$LAUNCHD_PLIST"; then
    # launchd can intermittently return bootstrap I/O errors during rapid restarts.
    # Retry once after an explicit bootout to make restart behavior predictable.
    warn "launchd bootstrap failed, retrying once ..."
    launchctl bootout "gui/$(id -u)/${LAUNCHD_LABEL}" 2>/dev/null || true
    sleep 1
    launchctl bootstrap "gui/$(id -u)" "$LAUNCHD_PLIST"
  fi

  info "Installed launchd service ($LAUNCHD_LABEL)"
  info "Proxy starting on port $port (auto-starts on login)"
  info "Logs: $LOG_DIR/proxy.log"
}

launchd_stop() {
  launchctl bootout "gui/$(id -u)/${LAUNCHD_LABEL}" 2>/dev/null && \
    info "Service stopped." || warn "Service not running."
}

launchd_is_running() {
  launchctl print "gui/$(id -u)/${LAUNCHD_LABEL}" &>/dev/null
}

launchd_uninstall() {
  launchctl bootout "gui/$(id -u)/${LAUNCHD_LABEL}" 2>/dev/null || true
  rm -f "$LAUNCHD_PLIST"
  info "Removed launchd service."
}

# ── Service: Linux systemd ──────────────────────────────────────────────────

systemd_install() {
  local port="$1"
  local config="$2"

  ensure_log_dir
  mkdir -p "$SYSTEMD_DIR"

  local env_lines=""
  if [ -f "$PROJECT_DIR/.env" ]; then
    while IFS= read -r line; do
      [[ "$line" =~ ^[[:space:]]*# ]] && continue
      [[ -z "$line" ]] && continue
      env_lines="${env_lines}Environment=${line}"$'\n'
    done < "$PROJECT_DIR/.env"
  fi

  cat > "$SYSTEMD_FILE" <<UNIT
[Unit]
Description=LiteLLM Proxy
After=network.target

[Service]
Type=simple
WorkingDirectory=${PROJECT_DIR}
ExecStart=${VENV_DIR}/bin/litellm --config ${config} --port ${port} $(_perf_flags)
Restart=on-failure
RestartSec=5

Environment=PATH=${VENV_DIR}/bin:/usr/local/bin:/usr/bin:/bin
Environment=VIRTUAL_ENV=${VENV_DIR}
${env_lines}
StandardOutput=append:${LOG_DIR}/proxy.log
StandardError=append:${LOG_DIR}/proxy-error.log

[Install]
WantedBy=default.target
UNIT

  echo "$port" > "$PORT_FILE"

  systemctl --user daemon-reload
  systemctl --user enable "$SYSTEMD_UNIT"
  systemctl --user start "$SYSTEMD_UNIT"

  info "Installed systemd user service ($SYSTEMD_UNIT)"
  info "Proxy starting on port $port (auto-starts on login)"
  info "Logs: $LOG_DIR/proxy.log"

  # Enable lingering so the service survives logout (requires loginctl).
  if command -v loginctl &>/dev/null; then
    if ! loginctl show-user "$USER" --property=Linger 2>/dev/null | grep -q "yes"; then
      warn "Enabling loginctl linger for $USER (keeps service running after logout)"
      loginctl enable-linger "$USER" 2>/dev/null || true
    fi
  fi
}

systemd_stop() {
  systemctl --user stop "$SYSTEMD_UNIT" 2>/dev/null && \
    info "Service stopped." || warn "Service not running."
}

systemd_is_running() {
  systemctl --user is-active "$SYSTEMD_UNIT" &>/dev/null
}

systemd_uninstall() {
  systemctl --user stop "$SYSTEMD_UNIT" 2>/dev/null || true
  systemctl --user disable "$SYSTEMD_UNIT" 2>/dev/null || true
  rm -f "$SYSTEMD_FILE"
  systemctl --user daemon-reload
  info "Removed systemd service."
}

has_systemd_user() {
  # systemctl --user requires a dbus session bus and XDG_RUNTIME_DIR.
  # Without these, the command hangs on headless Linux / SSH / containers.
  [ -n "${XDG_RUNTIME_DIR:-}" ] || return 1
  command -v systemctl &>/dev/null || return 1
  local bin
  bin="$(type -P timeout 2>/dev/null || true)"
  if [ -n "$bin" ]; then
    "$bin" -k 3 5 systemctl --user status >/dev/null 2>&1
  else
    systemctl --user status >/dev/null 2>&1
  fi
}

# ── Service: nohup fallback (servers without systemd user bus) ─────────────

PIDFILE="$PROJECT_DIR/.proxy.pid"

nohup_start() {
  local port="$1"
  local config="$2"

  ensure_log_dir
  activate_venv
  load_env

  echo "$port" > "$PORT_FILE"

  # shellcheck disable=SC2046
  nohup "$VENV_DIR/bin/litellm" --config "$config" --port "$port" $(_perf_flags) \
    >> "$LOG_DIR/proxy.log" 2>> "$LOG_DIR/proxy-error.log" &
  local pid=$!
  echo "$pid" > "$PIDFILE"
  disown "$pid" 2>/dev/null || true

  info "Proxy started in background (PID $pid, port $port)"
  info "Logs: $LOG_DIR/proxy.log"
  info "Note: add 'litellmctl start' to cron @reboot for auto-start"
}

nohup_stop() {
  local pid=""
  if [ -f "$PIDFILE" ]; then
    pid=$(cat "$PIDFILE")
  fi
  if [ -z "$pid" ]; then
    pid=$(find_proxy_pid)
  fi
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null
    rm -f "$PIDFILE"
    info "Stopped (PID $pid)."
  else
    rm -f "$PIDFILE"
    warn "No proxy found."
  fi
}

nohup_is_running() {
  if [ -f "$PIDFILE" ]; then
    local pid
    pid=$(cat "$PIDFILE")
    kill -0 "$pid" 2>/dev/null && return 0
  fi
  [ -n "$(find_proxy_pid)" ]
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_setup_completions() {
  local shell_name rc_file

  shell_name="$(basename "${SHELL:-/bin/bash}")"
  case "$shell_name" in
    zsh)  rc_file="$HOME/.zshrc" ;;
    *)    rc_file="$HOME/.bashrc" ;;
  esac

  if grep -qF "alias litellmctl=" "$rc_file" 2>/dev/null; then
    info "litellmctl already set up in $rc_file"
    return
  fi

  local block
  if [ "$shell_name" = "zsh" ]; then
    block='
# LiteLLM CLI
alias litellmctl="~/.litellm/bin/litellmctl"
eval "$(~/.litellm/bin/litellmctl --zsh-completions)"'
  else
    block='
# LiteLLM CLI
alias litellmctl="~/.litellm/bin/litellmctl"
eval "$(~/.litellm/bin/litellmctl --completions)"'
  fi

  printf '%s\n' "$block" >> "$rc_file"
  info "Added litellmctl alias + tab completion to $rc_file"
  info "Run: source $rc_file  (or open a new terminal)"
}

cmd_install() {
  local install_args=()
  local db_mode="${LITELLM_INSTALL_DB_SETUP:-}"  # yes|no|keep|empty(auto prompt)
  local db_mode_flag=""
  local post_sync_only=false
  local env_file="$PROJECT_DIR/.env"
  local pre_sha=""
  local post_sha=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --with-db|--db)     db_mode="yes"; db_mode_flag="--with-db"; shift ;;
      --without-db|--no-db) db_mode="no"; db_mode_flag="--without-db"; shift ;;
      --_post-sync)       post_sync_only=true; shift ;;
      *)                  install_args+=("$1"); shift ;;
    esac
  done

  if ! $post_sync_only; then
    pre_sha="$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || true)"
    if [ ${#install_args[@]} -gt 0 ]; then
      "$BIN_DIR/install" "${install_args[@]}"
    else
      "$BIN_DIR/install"
    fi
    post_sha="$(git -C "$PROJECT_DIR" rev-parse HEAD 2>/dev/null || true)"
    if [ -n "$pre_sha" ] && [ -n "$post_sha" ] && [ "$pre_sha" != "$post_sha" ]; then
      info "Repository updated during install. Reloading latest litellmctl ..."
      local reexec=("$PROJECT_DIR/bin/litellmctl" "install" "--_post-sync")
      if [ -n "$db_mode_flag" ]; then
        reexec+=("$db_mode_flag")
      fi
      exec "${reexec[@]}"
    fi
  fi

  # Set up local DB now that the venv is guaranteed to exist
  activate_venv
  load_env
  if [ -z "$db_mode" ]; then
    if is_interactive; then
      if grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
        printf "\n  Local database is already configured. [K]eep DB mode or [D]isable DB mode? [K/d] "
        local keep_or_disable
        read -r keep_or_disable </dev/tty || keep_or_disable="k"
        case "$keep_or_disable" in
          [dD]*) db_mode="no" ;;
          *)     db_mode="keep" ;;
        esac
      else
        printf "\n  Set up local PostgreSQL database for LiteLLM now? [Y/n] "
        local answer
        read -r answer </dev/tty || answer="y"
        case "$answer" in
          [nN]*) db_mode="no" ;;
          *)     db_mode="yes" ;;
        esac
      fi
    else
      # Non-interactive installs should converge fully without manual follow-up.
      if grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
        db_mode="keep"
      else
        db_mode="yes"
      fi
    fi
  fi

  if [ "$db_mode" = "yes" ]; then
    if ! ensure_db_ready; then
      warn "Local DB setup reported errors."
    fi
    load_env  # reload to pick up DATABASE_URL written by ensure_db_ready
    if ! _db_is_ready; then
      if _maybe_offer_fresh_db_recovery; then
        ensure_db_ready || true
        load_env
      fi
      if ! _db_is_ready; then
        error "Database is not ready after install-time setup."
        error "Install cannot complete DB mode reliably. Re-run: litellmctl install --with-db"
        return 1
      fi
    fi
  elif [ "$db_mode" = "keep" ]; then
    if ! _db_is_ready; then
      warn "Existing DB mode is enabled, but DB is not fully ready."
      info "Attempting automatic DB repair ..."
      ensure_db_ready || true
      load_env
      if ! _db_is_ready; then
        if _maybe_offer_fresh_db_recovery; then
          ensure_db_ready || true
          load_env
        fi
        if ! _db_is_ready; then
          error "Automatic DB repair did not complete successfully."
          error "DB mode is still enabled but unhealthy. Re-run: litellmctl install --with-db"
          return 1
        fi
      else
        info "DB repair complete; keeping DB mode enabled."
      fi
    else
      info "Keeping existing DB mode."
    fi
  else
    _remove_db_env_config
    unset DATABASE_URL DISABLE_SCHEMA_UPDATE 2>/dev/null || true
    warn "Skipped local DB setup during install."
    info "Any existing local DB config was removed from .env."
    info "Re-run with 'litellmctl install --with-db' to enable local DB again."
  fi

  # Ask to restart if service is running
  local running=false
  if is_macos && launchd_is_running; then running=true; fi
  if is_linux && systemd_is_running; then running=true; fi
  if nohup_is_running; then running=true; fi
  if [ -n "$(find_proxy_pid)" ]; then running=true; fi

  if $running; then
    if is_interactive; then
      printf "\n  Proxy is running. Restart now? [Y/n] "
      read -r answer </dev/tty || answer="n"
      case "$answer" in
        [nN]*) info "Skipped restart. Run 'litellmctl restart' when ready." ;;
        *)     cmd_restart ;;
      esac
    else
      info "Proxy is running. Run 'litellmctl restart' to apply changes."
    fi
  fi
}

cmd_auth() {
  activate_venv
  load_env
  exec python3 "$BIN_DIR/auth" "$@"
}

cmd_start() {
  load_env
  local port=4040
  local config="$PROJECT_DIR/config.yaml"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)   port="$2"; shift 2 ;;
      --config) config="$2"; shift 2 ;;
      *)        shift ;;
    esac
  done

  activate_venv
  load_env

  kill_stale_on_port "$port"

  if is_macos; then
    launchd_install "$port" "$config"
  elif is_linux && has_systemd_user; then
    systemd_install "$port" "$config"
  else
    nohup_start "$port" "$config"
  fi
  _wait_for_proxy_ready "$port" || true
}

cmd_stop() {
  local port
  port=$(get_proxy_port)
  if is_macos && launchd_is_running; then
    launchd_stop
  elif is_linux && systemd_is_running; then
    systemd_stop
  else
    nohup_stop
  fi
  kill_stale_on_port "$port"
}

cmd_restart() {
  load_env
  info "Restarting proxy ..."
  local port config
  port=$(get_proxy_port)
  config="$PROJECT_DIR/config.yaml"

  if is_macos && launchd_is_running; then
    launchd_stop
  elif is_linux && systemd_is_running; then
    systemctl --user stop "$SYSTEMD_UNIT" 2>/dev/null || true
  else
    nohup_stop
  fi

  sleep 1
  kill_stale_on_port "$port"

  activate_venv
  load_env

  if is_macos; then
    launchd_install "$port" "$config"
  elif is_linux && has_systemd_user; then
    systemctl --user daemon-reload
    systemctl --user start "$SYSTEMD_UNIT"
    info "Restarted."
  else
    nohup_start "$port" "$config"
  fi
  _wait_for_proxy_ready "$port" || true
}

cmd_logs() {
  ensure_log_dir
  local logfile="$LOG_DIR/proxy.log"
  local errfile="$LOG_DIR/proxy-error.log"

  if [ ! -f "$logfile" ] && [ ! -f "$errfile" ]; then
    warn "No log files found yet. Start the proxy first with 'litellmctl start'."
    exit 0
  fi

  info "Tailing $LOG_DIR  (Ctrl+C to stop)"
  tail -f "$logfile" "$errfile" 2>/dev/null
}

cmd_proxy() {
  activate_venv
  load_env
  unset DEBUG 2>/dev/null || true

  local port=4040
  local config="$PROJECT_DIR/config.yaml"
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port)   port="$2"; shift 2 ;;
      --config) config="$2"; shift 2 ;;
      *)        extra_args+=("$1"); shift ;;
    esac
  done

  kill_stale_on_port "$port"

  echo "$port" > "$PORT_FILE"

  info "Starting LiteLLM proxy on port $port (foreground) ..."
  # shellcheck disable=SC2046
  if [ ${#extra_args[@]} -gt 0 ]; then
    exec litellm --config "$config" --port "$port" $(_perf_flags) "${extra_args[@]}"
  else
    exec litellm --config "$config" --port "$port" $(_perf_flags)
  fi
}

cmd_init_env() {
  local env_file="$PROJECT_DIR/.env"
  local changed=0

  if [ ! -f "$env_file" ]; then
    warn "No .env file found. Copy .env.example first:"
    warn "  cp $PROJECT_DIR/.env.example $env_file"
    exit 1
  fi

  # Upsert a single key=value in .env. Only touches the target key;
  # all other lines (comments, blanks, other vars) are preserved as-is.
  _upsert_env_var() {
    local var="$1" val="$2"
    if grep -q "^${var}=" "$env_file" 2>/dev/null; then
      local old_val
      old_val=$(grep "^${var}=" "$env_file" | head -1 | cut -d= -f2-)
      if [ "$old_val" = "$val" ]; then
        return 1  # already correct
      fi
      sed -i.bak "s|^${var}=.*|${var}=${val}|" "$env_file"
      rm -f "$env_file.bak"
      changed=1
      printf "    \033[36m↻\033[0m %s: %s → %s\n" "$var" "$old_val" "$val"
      return 0
    else
      printf '\n%s=%s' "$var" "$val" >> "$env_file"
      # ensure trailing newline
      printf '\n' >> "$env_file"
      changed=1
      printf "    \033[32m+\033[0m %s=%s\n" "$var" "$val"
      return 0
    fi
  }

  _process_auth() {
    local auth_file="$1" dir_var="$2" file_var="$3"
    if [ -f "$PROJECT_DIR/$auth_file" ]; then
      local sub_changed=0
      _upsert_env_var "$dir_var" "$PROJECT_DIR" && sub_changed=1
      _upsert_env_var "$file_var" "$auth_file" && sub_changed=1
      if [ $sub_changed -eq 0 ]; then
        printf "  \033[32m✓\033[0m %-30s (up to date)\n" "$auth_file"
      else
        printf "  \033[32m✓\033[0m %-30s synced\n" "$auth_file"
      fi
    else
      printf "  \033[33m-\033[0m %-30s (not found, skipped)\n" "$auth_file"
    fi
  }

  info "Scanning $PROJECT_DIR for auth files ..."
  _process_auth "auth.chatgpt.json"      "CHATGPT_TOKEN_DIR"      "CHATGPT_AUTH_FILE"
  _process_auth "auth.gemini_cli.json"    "GEMINI_CLI_TOKEN_DIR"   "GEMINI_CLI_AUTH_FILE"
  _process_auth "auth.qwen_portal.json"   "QWEN_PORTAL_TOKEN_DIR"  "QWEN_PORTAL_AUTH_FILE"
  _process_auth "auth.kimi_code.json"     "KIMI_CODE_TOKEN_DIR"    "KIMI_CODE_AUTH_FILE"

  info "Ensuring required settings ..."
  _upsert_env_var "LITELLM_LOCAL_MODEL_COST_MAP" "true" || true

  if [ $changed -eq 0 ]; then
    printf "\n"
    info "All paths and settings already up to date."
  else
    printf "\n"
    info ".env updated — no existing entries were removed."
  fi
}

# ── Database helpers ────────────────────────────────────────────────────────

# Prisma expects a hostname; on Linux we force socket transport explicitly.
_append_linux_socket_host_param() {
  local url="$1"
  is_linux || { printf '%s\n' "$url"; return 0; }
  [[ "$url" == *"host="* ]] && { printf '%s\n' "$url"; return 0; }
  if [[ "$url" == *"?"* ]]; then
    printf '%s&host=%%2Fvar%%2Frun%%2Fpostgresql\n' "$url"
  else
    printf '%s?host=%%2Fvar%%2Frun%%2Fpostgresql\n' "$url"
  fi
}

# ensure_db_ready — called during install when DB setup is enabled.
# Idempotent: safe to call every time. Skips gracefully if postgres is absent.
# Returns 0 on success or skip, 1 only on hard errors that should block start.
ensure_db_ready() {
  local env_file="$PROJECT_DIR/.env"
  local db_name="litellm"
  local db_user="${PGUSER:-${USER:-postgres}}"
  local default_url="postgresql://${db_user}@localhost/${db_name}"
  if is_linux; then
    default_url="$(_append_linux_socket_host_param "$default_url")"
  fi

  # ── Step -1: Ensure PostgreSQL tooling exists ─────────────────────────────
  if ! _ensure_postgres_tools; then
    warn "PostgreSQL dependencies are missing and could not be auto-installed."
    warn "Skipping DB setup for now."
    return 0
  fi

  # ── Step 0: Ensure .env exists (copy from example if needed) ─────────────
  if [ ! -f "$env_file" ]; then
    if [ -f "$PROJECT_DIR/.env.example" ]; then
      cp "$PROJECT_DIR/.env.example" "$env_file"
      warn "Created .env from .env.example — fill in your API keys."
    else
      touch "$env_file"
    fi
  fi

  # ── Step 1: Auto-configure DATABASE_URL if not already set ───────────────
  if ! grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
    # Auto-configure if psql exists; postgres can be started in Step 2.
    if command -v psql &>/dev/null; then
      info "Configuring local database (DATABASE_URL) ..."
      printf '\nDATABASE_URL=%s\n' "$default_url" >> "$env_file"
      # Reload so the variable is visible for the rest of this function
      set -a; source "$env_file"; set +a
    else
      warn "PostgreSQL client (psql) not found — skipping DB setup."
      if is_linux; then
        warn "Install PostgreSQL first (example: sudo apt-get install -y postgresql postgresql-client)."
      elif is_macos; then
        warn "Install PostgreSQL first (example: brew install postgresql@14)."
      fi
      return 0  # postgres not available, skip silently
    fi
  fi

  # ── Step 1b: Avoid expensive Prisma schema updates on every server boot ───
  # LiteLLM can run prisma schema updates at each startup. On some systems this
  # can block worker boot and make the proxy appear "running" but unreachable.
  if ! grep -q "^DISABLE_SCHEMA_UPDATE=" "$env_file" 2>/dev/null; then
    info "Setting DISABLE_SCHEMA_UPDATE=true (recommended for stable startup) ..."
    printf '\nDISABLE_SCHEMA_UPDATE=true\n' >> "$env_file"
    set -a; source "$env_file"; set +a
  fi

  # ── Step 2: Ensure postgres is running ───────────────────────────────────
  if ! pg_isready -q 2>/dev/null; then
    if ! _pg_start_local; then
      warn "PostgreSQL not running and could not start it — skipping DB setup."
      warn "Start it manually, then run 'litellmctl start' again."
      return 0  # warn but don't abort proxy start
    fi
  fi

  # ── Step 3: Determine the DB name from DATABASE_URL ──────────────────────
  local db_url="${DATABASE_URL:-$default_url}"
  case "$db_url" in
    postgresql://localhost/*|postgres://localhost/*)
      local db_path normalized_url
      db_path="${db_url#*://localhost/}"
      normalized_url="postgresql://${db_user}@localhost/${db_path}"
      if is_linux; then
        normalized_url="$(_append_linux_socket_host_param "$normalized_url")"
        warn "DATABASE_URL had no DB user; normalizing and forcing Linux socket transport for Prisma."
      else
        warn "DATABASE_URL has no DB user; normalizing to '${db_user}@localhost'."
      fi
      if grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
        sed -i.bak "s|^DATABASE_URL=.*|DATABASE_URL=${normalized_url}|" "$env_file"
        rm -f "$env_file.bak"
      fi
      db_url="$normalized_url"
      export DATABASE_URL="$db_url"
      ;;
    postgresql://*@/*|postgres://*@/*)
      local prefix path_part user_part normalized_socket_url
      prefix="${db_url%%@/*}"
      user_part="${prefix#*://}"
      path_part="${db_url#*@/}"
      if [ -z "$path_part" ]; then
        path_part="$db_name"
      fi
      normalized_socket_url="postgresql://${user_part}@localhost/${path_part}"
      normalized_socket_url="$(_append_linux_socket_host_param "$normalized_socket_url")"
      warn "DATABASE_URL used socket shorthand; converting to Prisma-compatible URL."
      if grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
        sed -i.bak "s|^DATABASE_URL=.*|DATABASE_URL=${normalized_socket_url}|" "$env_file"
        rm -f "$env_file.bak"
      fi
      db_url="$normalized_socket_url"
      export DATABASE_URL="$db_url"
      ;;
    postgresql://*@localhost/*|postgres://*@localhost/*)
      if is_linux; then
        local linux_url
        linux_url="$(_append_linux_socket_host_param "$db_url")"
        if [ "$linux_url" != "$db_url" ]; then
          warn "DATABASE_URL uses localhost on Linux; forcing socket transport for Prisma."
          if grep -q "^DATABASE_URL=" "$env_file" 2>/dev/null; then
            sed -i.bak "s|^DATABASE_URL=.*|DATABASE_URL=${linux_url}|" "$env_file"
            rm -f "$env_file.bak"
          fi
          db_url="$linux_url"
          export DATABASE_URL="$db_url"
        fi
      fi
      ;;
  esac
  local parsed_db
  parsed_db=$(python3 -c \
    "from urllib.parse import urlparse; u=urlparse('${db_url}'); print(u.path.lstrip('/') or '${db_name}')" \
    2>/dev/null) || parsed_db="$db_name"

  # ── Step 4: Create the database if it doesn't exist ──────────────────────
  if ! psql -lqt 2>/dev/null | cut -d'|' -f1 | grep -qw "$parsed_db"; then
    info "Creating database '$parsed_db' ..."
    if ! createdb "$parsed_db" 2>/dev/null; then
      if ! _linux_bootstrap_role_and_db "$db_user" "$parsed_db"; then
        warn "Could not create database '$parsed_db' — skipping DB setup."
        return 0
      fi
    fi
  fi

  # ── Step 5: Run migrations only if not yet applied ───────────────────────
  # Use LiteLLM_SpendLogs as a sentinel — present after first migration run.
  if ! psql "$db_url" -qc 'SELECT 1 FROM "LiteLLM_SpendLogs" LIMIT 0' &>/dev/null; then
    if ! _ensure_prisma_installed; then
      warn "Prisma dependency missing — skipping DB migrations."
      warn "Run 'litellmctl install' to repair the environment."
      return 0
    fi
    if ! _ensure_prisma_generated; then
      warn "Prisma client generation failed — skipping DB migrations."
      warn "Run: (cd $PROJECT_DIR/litellm/litellm/proxy && prisma generate && prisma py generate)"
      return 0
    fi
    info "Running database migrations ..."
    # Export DATABASE_URL so the litellm subprocess can see it
    export DATABASE_URL="$db_url"
    if ! _run_db_migrations "$parsed_db"; then
      warn "Migration command failed on first attempt; retrying after permission repair ..."
      if is_linux; then
        _linux_bootstrap_role_and_db "$db_user" "$parsed_db" || true
      fi
      _run_db_migrations "$parsed_db" || return 1
    fi
    info "Database ready."
  fi

  # ── Step 6: Write usage-collection flags to .env ──────────────────────────
  _patch_db_env_flags || true

  return 0
}

# Ensure prisma is installed in the current virtualenv.
_ensure_prisma_installed() {
  python3 -c 'import prisma' &>/dev/null && return 0
  info "Installing missing prisma dependency for DB migrations ..."
  if pip install --quiet prisma; then
    return 0
  fi
  return 1
}

# Start local PostgreSQL service (macOS/Linux); returns 0 if postgres becomes ready.
_pg_start_local() {
  _pg_start_brew && return 0
  _pg_start_linux && return 0
  return 1
}

# Ensure prisma client/binaries are generated for this virtualenv.
_ensure_prisma_generated() {
  local prisma_dir="$PROJECT_DIR/litellm/litellm/proxy"
  local prisma_schema="$prisma_dir/schema.prisma"
  [ -f "$prisma_schema" ] || return 1
  command -v prisma &>/dev/null || return 1

  (cd "$prisma_dir" && prisma generate &>/dev/null && prisma py generate &>/dev/null)
}

_resolve_proxy_prisma_schema() {
  python3 - <<'PY' 2>/dev/null
import importlib.util
from pathlib import Path
spec = importlib.util.find_spec("litellm_proxy_extras")
if not spec or not spec.origin:
    raise SystemExit(1)
root = Path(spec.origin).resolve().parent
schema = root / "schema.prisma"
if schema.exists():
    print(schema)
PY
}

_run_db_migrations() {
  local parsed_db="$1"
  local schema
  local mig_log
  mig_log="$LOG_DIR/db-migrate.log"
  ensure_log_dir
  : > "$mig_log"
  schema="$(_resolve_proxy_prisma_schema || true)"

  if [ -n "$schema" ] && [ -f "$schema" ] && command -v prisma &>/dev/null; then
    (prisma migrate deploy --schema "$schema" >>"$mig_log" 2>&1) || true
  fi
  # Fallback to LiteLLM's internal migration/bootstrap path.
  (litellm --config "$PROJECT_DIR/config.yaml" --skip_server_startup >>"$mig_log" 2>&1) || true

  if psql "${DATABASE_URL}" -qc 'SELECT 1 FROM "LiteLLM_SpendLogs" LIMIT 0' &>/dev/null; then
    return 0
  fi

  warn "Database migrations are still pending."
  warn "Recent migration output:"
  tail -n 25 "$mig_log" 2>/dev/null || true
  return 1
}

# Start PostgreSQL via Homebrew; returns 0 if postgres becomes ready, 1 otherwise.
_pg_start_brew() {
  is_macos || return 1
  command -v brew &>/dev/null || return 1
  brew services start postgresql@14 &>/dev/null \
    || brew services start postgresql &>/dev/null \
    || return 1
  local i=0
  while ! pg_isready -q 2>/dev/null && [ $i -lt 12 ]; do
    sleep 1; (( i++ ))
  done
  pg_isready -q 2>/dev/null
}

# Start PostgreSQL on Linux via common service managers; returns 0 on readiness.
_pg_start_linux() {
  is_linux || return 1

  # Debian/Ubuntu cluster manager (best signal on Ubuntu).
  if command -v pg_ctlcluster &>/dev/null; then
    local v
    for v in 17 16 15 14 13 12; do
      pg_ctlcluster "$v" main start &>/dev/null || _run_with_sudo_if_needed pg_ctlcluster "$v" main start &>/dev/null || true
    done
  fi

  # systemd / service fallbacks.
  if command -v systemctl &>/dev/null; then
    systemctl start postgresql &>/dev/null || _run_with_sudo_if_needed systemctl start postgresql &>/dev/null || true
  elif command -v service &>/dev/null; then
    service postgresql start &>/dev/null || _run_with_sudo_if_needed service postgresql start &>/dev/null || true
  fi

  local i=0
  while ! pg_isready -q 2>/dev/null && [ $i -lt 20 ]; do
    sleep 1; (( i++ ))
  done
  pg_isready -q 2>/dev/null
}

_linux_bootstrap_role_and_db() {
  local db_user="$1"
  local db_name="$2"
  is_linux || return 1
  [[ "$db_user" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || return 1
  [[ "$db_name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || return 1

  info "Attempting PostgreSQL bootstrap via postgres superuser ..."
  local role_exists
  role_exists="$(_run_with_sudo_if_needed -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname='${db_user}'" 2>/dev/null || true)"
  if ! echo "$role_exists" | grep -q 1; then
    _run_with_sudo_if_needed -u postgres createuser --createdb "$db_user" &>/dev/null || return 1
  else
    # Ensure role has enough privileges for local lifecycle commands.
    _run_with_sudo_if_needed -u postgres psql -d postgres -c "ALTER ROLE \"${db_user}\" CREATEDB;" &>/dev/null || true
  fi

  _run_with_sudo_if_needed -u postgres createdb -O "$db_user" "$db_name" &>/dev/null \
    || _run_with_sudo_if_needed -u postgres psql -d postgres -c "ALTER DATABASE \"${db_name}\" OWNER TO \"${db_user}\";" &>/dev/null \
    || true

  # Repair common permission issues for existing DB/schema objects.
  _run_with_sudo_if_needed -u postgres psql -d "$db_name" -c "GRANT ALL ON SCHEMA public TO \"${db_user}\";" &>/dev/null || true
  _run_with_sudo_if_needed -u postgres psql -d "$db_name" -c "GRANT ALL PRIVILEGES ON ALL TABLES IN SCHEMA public TO \"${db_user}\";" &>/dev/null || true
  _run_with_sudo_if_needed -u postgres psql -d "$db_name" -c "GRANT ALL PRIVILEGES ON ALL SEQUENCES IN SCHEMA public TO \"${db_user}\";" &>/dev/null || true
  _run_with_sudo_if_needed -u postgres psql -d "$db_name" -c "ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON TABLES TO \"${db_user}\";" &>/dev/null || true
  _run_with_sudo_if_needed -u postgres psql -d "$db_name" -c "ALTER DEFAULT PRIVILEGES IN SCHEMA public GRANT ALL ON SEQUENCES TO \"${db_user}\";" &>/dev/null || true

  psql -lqt 2>/dev/null | cut -d'|' -f1 | grep -qw "$db_name"
}

# Ensure postgres client/server tools exist. Returns 0 if psql is available.
_ensure_postgres_tools() {
  command -v psql &>/dev/null && return 0

  if is_macos; then
    command -v brew &>/dev/null || return 1
    info "Installing PostgreSQL via Homebrew ..."
    brew install postgresql@14 &>/dev/null || brew install postgresql &>/dev/null || return 1
    command -v psql &>/dev/null
    return $?
  fi

  if is_linux; then
    info "Installing PostgreSQL dependencies ..."
    if command -v apt-get &>/dev/null; then
      _run_with_sudo_if_needed apt-get update -qq &>/dev/null || true
      _run_with_sudo_if_needed apt-get install -y -qq postgresql postgresql-client &>/dev/null \
        || return 1
    elif command -v dnf &>/dev/null; then
      _run_with_sudo_if_needed dnf install -y -q postgresql postgresql-server &>/dev/null \
        || return 1
    elif command -v yum &>/dev/null; then
      _run_with_sudo_if_needed yum install -y -q postgresql postgresql-server &>/dev/null \
        || return 1
    elif command -v pacman &>/dev/null; then
      _run_with_sudo_if_needed pacman -S --noconfirm --needed postgresql &>/dev/null \
        || return 1
    elif command -v apk &>/dev/null; then
      _run_with_sudo_if_needed apk add --quiet postgresql postgresql-client &>/dev/null \
        || return 1
    else
      return 1
    fi
    command -v psql &>/dev/null
    return $?
  fi

  return 1
}

_remove_db_env_config() {
  local env_file="$PROJECT_DIR/.env"
  [ -f "$env_file" ] || return 0
  local tmp
  tmp="$(mktemp)"
  awk '!/^DATABASE_URL=|^DISABLE_SCHEMA_UPDATE=|^STORE_MODEL_IN_DB=|^PROXY_BATCH_WRITE_AT=|^STORE_PROMPTS_IN_SPEND_LOGS=/' "$env_file" > "$tmp"
  mv "$tmp" "$env_file"
}

# _patch_db_env_flags — write usage-collection env vars when DB is enabled.
# All flags are read directly from the environment by LiteLLM at startup.
# LITELLM_LOCAL_MODEL_COST_MAP is always written (not DB-specific) so that
# our custom provider entries in model_prices_and_context_window.json are used
# instead of the remote upstream file which doesn't know about our providers.
# Idempotent: only appends vars that are not already present.
_patch_db_env_flags() {
  local env_file="$PROJECT_DIR/.env"
  local dirty=false
  if ! grep -q '^LITELLM_LOCAL_MODEL_COST_MAP=' "$env_file" 2>/dev/null; then
    printf 'LITELLM_LOCAL_MODEL_COST_MAP=true\n' >> "$env_file"
    dirty=true
  fi
  if ! grep -q '^STORE_MODEL_IN_DB=' "$env_file" 2>/dev/null; then
    printf 'STORE_MODEL_IN_DB=true\n' >> "$env_file"
    dirty=true
  fi
  if ! grep -q '^PROXY_BATCH_WRITE_AT=' "$env_file" 2>/dev/null; then
    printf 'PROXY_BATCH_WRITE_AT=10\n' >> "$env_file"
    dirty=true
  fi
  if ! grep -q '^STORE_PROMPTS_IN_SPEND_LOGS=' "$env_file" 2>/dev/null; then
    printf 'STORE_PROMPTS_IN_SPEND_LOGS=true\n' >> "$env_file"
    dirty=true
  fi
  "$dirty" && info "DB usage-collection flags written to .env." || true
}

_db_is_ready() {
  local db_url="${DATABASE_URL:-}"
  [ -n "$db_url" ] || return 1
  command -v psql &>/dev/null || return 1
  pg_isready -q 2>/dev/null || return 1
  psql "$db_url" -qc 'SELECT 1 FROM "LiteLLM_SpendLogs" LIMIT 0' &>/dev/null
}

_db_name_from_url() {
  local db_url="${1:-${DATABASE_URL:-}}"
  [ -n "$db_url" ] || { printf 'litellm\n'; return 0; }
  python3 -c \
    "from urllib.parse import urlparse; u=urlparse('${db_url}'); print((u.path.lstrip('/') or 'litellm').split('?')[0])" \
    2>/dev/null || printf 'litellm\n'
}

_db_user_from_url() {
  local db_url="${1:-${DATABASE_URL:-}}"
  local default_user="${PGUSER:-${USER:-postgres}}"
  [ -n "$db_url" ] || { printf '%s\n' "$default_user"; return 0; }
  python3 -c \
    "from urllib.parse import urlparse; u=urlparse('${db_url}'); print(u.username or '${default_user}')" \
    2>/dev/null || printf '%s\n' "$default_user"
}

_maybe_offer_fresh_db_recovery() {
  is_interactive || return 1
  local db_url="${DATABASE_URL:-}"
  [ -n "$db_url" ] || return 1

  local db_name db_user answer
  db_name="$(_db_name_from_url "$db_url")"
  db_user="$(_db_user_from_url "$db_url")"

  [[ "$db_name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || return 1
  [[ "$db_user" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || return 1

  printf "\n  DB migrations are still failing. This can indicate a corrupt local DB state.\n"
  printf "  Create a fresh local DB now? This will DROP database '%s'. [y/N] " "$db_name"
  read -r answer </dev/tty || answer="n"
  case "$answer" in
    [yY]*)
      info "Resetting local database '$db_name' ..."
      if is_linux; then
        _run_with_sudo_if_needed -u postgres dropdb --if-exists "$db_name" &>/dev/null \
          || dropdb --if-exists "$db_name" &>/dev/null \
          || true
        _run_with_sudo_if_needed -u postgres createdb -O "$db_user" "$db_name" &>/dev/null \
          || createdb "$db_name" &>/dev/null \
          || return 1
        _linux_bootstrap_role_and_db "$db_user" "$db_name" || true
      else
        dropdb --if-exists "$db_name" &>/dev/null || true
        createdb "$db_name" &>/dev/null || return 1
      fi
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

cmd_uninstall_service() {
  if is_macos; then
    launchd_uninstall
  elif is_linux && [ -f "$SYSTEMD_FILE" ]; then
    systemd_uninstall
  else
    nohup_stop
    rm -f "$PIDFILE" "$PORT_FILE"
    info "Cleaned up nohup-managed proxy."
  fi
}

_db_status() {
  local db_url="${DATABASE_URL:-}"

  printf "\033[1mDatabase\033[0m\n"
  if [ -z "$db_url" ]; then
    printf "  \033[33mNot configured\033[0m\n\n"
    return
  fi

  printf "  URL: %s\n" "$db_url"

  if ! command -v psql &>/dev/null; then
    printf "  Status: \033[33mpsql not found\033[0m\n\n"
    return
  fi

  if ! pg_isready -q 2>/dev/null; then
    printf "  Status: \033[31mPostgreSQL not running\033[0m\n\n"
    return
  fi

  if psql "$db_url" -qc 'SELECT 1 FROM "LiteLLM_SpendLogs" LIMIT 0' &>/dev/null; then
    printf "  Status: \033[32mready\033[0m\n"
  elif psql "$db_url" -c '\q' &>/dev/null; then
    printf "  Status: \033[33mconnected, migrations pending\033[0m\n"
  else
    printf "  Status: \033[31mcannot connect\033[0m\n"
  fi
  printf "\n"
}

_proxy_http_health() {
  local port="$1"
  local health_url="http://127.0.0.1:${port}/health/readiness"
  if python3 - <<PY
import urllib.request
try:
    with urllib.request.urlopen("${health_url}", timeout=3) as r:
        raise SystemExit(0 if 200 <= r.status < 300 else 1)
except Exception:
    raise SystemExit(1)
PY
  then
    echo "healthy"
  else
    echo "unhealthy"
  fi
}

_wait_for_proxy_ready() {
  local port="$1"
  local tries=30
  local i=1
  while [ "$i" -le "$tries" ]; do
    if [ "$(_proxy_http_health "$port")" = "healthy" ]; then
      info "Proxy is healthy on port $port."
      return 0
    fi
    sleep 1
    (( i++ ))
  done
  warn "Proxy did not become healthy within ${tries}s."
  warn "Check logs with: litellmctl logs"
  return 1
}

cmd_status() {
  activate_venv
  load_env
  python3 "$BIN_DIR/auth" status

  local port pid health
  port=$(get_proxy_port)

  printf "\033[1mProxy\033[0m\n"

  if is_macos && launchd_is_running; then
    pid=$(find_proxy_pid)
    if [ -n "$pid" ]; then
      printf "  Service: \033[32mrunning\033[0m (launchd, auto-start enabled)\n"
    else
      printf "  Service: \033[33mloaded, but proxy not listening\033[0m (launchd)\n"
    fi
    printf "  Port:    %s\n" "$port"
    [ -n "$pid" ] && printf "  PID:     %s\n" "$pid"
    if [ -n "$pid" ]; then
      health=$(_proxy_http_health "$port")
      if [ "$health" = "healthy" ]; then
        printf "  Health:  \033[32mhealthy\033[0m\n"
      else
        printf "  Health:  \033[31munhealthy (HTTP checks timing out/failing)\033[0m\n"
      fi
    fi
    printf "\n"
  elif is_linux && systemd_is_running; then
    pid=$(find_proxy_pid)
    if [ -n "$pid" ]; then
      printf "  Service: \033[32mrunning\033[0m (systemd, auto-start enabled)\n"
    else
      printf "  Service: \033[33mloaded, but proxy not listening\033[0m (systemd)\n"
    fi
    printf "  Port:    %s\n" "$port"
    [ -n "$pid" ] && printf "  PID:     %s\n" "$pid"
    if [ -n "$pid" ]; then
      health=$(_proxy_http_health "$port")
      if [ "$health" = "healthy" ]; then
        printf "  Health:  \033[32mhealthy\033[0m\n"
      else
        printf "  Health:  \033[31munhealthy (HTTP checks timing out/failing)\033[0m\n"
      fi
    fi
    printf "\n"
  elif nohup_is_running; then
    pid=$(find_proxy_pid)
    [ -z "$pid" ] && [ -f "$PIDFILE" ] && pid=$(cat "$PIDFILE")
    if [ -n "$pid" ]; then
      printf "  Service: \033[32mrunning\033[0m (nohup, background)\n"
    else
      printf "  Service: \033[33mstarted, but proxy not listening\033[0m (nohup)\n"
    fi
    printf "  Port:    %s\n" "$port"
    [ -n "$pid" ] && printf "  PID:     %s\n" "$pid"
    if [ -n "$pid" ]; then
      health=$(_proxy_http_health "$port")
      if [ "$health" = "healthy" ]; then
        printf "  Health:  \033[32mhealthy\033[0m\n"
      else
        printf "  Health:  \033[31munhealthy (HTTP checks timing out/failing)\033[0m\n"
      fi
    fi
    printf "\n"
  else
    pid=$(find_proxy_pid)
    if [ -n "$pid" ]; then
      printf "  PID %s running on port %s (foreground)\n\n" "$pid" "$port"
    else
      printf "  \033[33mNot running\033[0m\n\n"
    fi
  fi

  _db_status
}

cmd_wizard() {
  activate_venv
  load_env
  exec python3 "$BIN_DIR/wizard" "$@"
}

show_help() {
  cat <<EOF

$(printf "\033[1mlitellmctl — LiteLLM Proxy Control\033[0m")

$(printf "\033[1mUsage:\033[0m")  litellmctl <command> [args...]

$(printf "\033[1mCommands:\033[0m")
  wizard               Interactive config.yaml generator (providers, tiers, fallbacks)
  install [--with-db|--without-db]
                     Install, update, or rebuild LiteLLM (prompts for DB setup)
  init-env             Detect auth files and update .env with correct paths
  auth chatgpt         Login to ChatGPT / Codex (browser PKCE)
  auth gemini          Login to Gemini CLI (browser PKCE)
  auth qwen            Login to Qwen Portal (device-code)
  auth kimi            Login to Kimi Code (device-code)
  auth refresh <p>     Refresh token for <chatgpt|gemini|qwen|kimi>
  auth export [p...]   Copy credentials as a paste-able transfer script
  auth import          Read credentials from stdin
  auth status          Show auth token status
  start [--port N]     Start proxy as background service (auto-start on boot)
  stop                 Stop the proxy service
  restart | r          Restart the proxy service
  logs                 Tail proxy logs
  proxy [--port N]     Start proxy in foreground (for debugging)
  uninstall-service    Remove the system service
  status               Show auth + proxy status
  toggle-claude        Toggle Claude Code between direct API and proxy
  setup-completions    Add litellmctl to your shell
  help                 Show this help

$(printf "\033[1mService:\033[0m")
  macOS: launchd agent (~/Library/LaunchAgents/)
  Linux: systemd user unit (~/.config/systemd/user/)
  Fallback: nohup background (servers without systemd user bus)

EOF
}

# ── Main ────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  show_help
  exit 0
fi

case "$1" in
  --completions)     generate_completions; exit 0 ;;
  --zsh-completions) generate_zsh_completions; exit 0 ;;
  wizard)            shift; cmd_wizard "$@" ;;
  install)           shift; cmd_install "$@" ;;
  update)            warn "'update' has been folded into 'install'."; info "Run: litellmctl install [--local]"; exit 0 ;;
  init-env)          shift; cmd_init_env ;;
  auth)              shift; cmd_auth "$@" ;;
  start)             shift; cmd_start "$@" ;;
  stop)              shift; cmd_stop ;;
  restart|r)         shift; cmd_restart ;;
  logs)              shift; cmd_logs ;;
  proxy)             shift; cmd_proxy "$@" ;;
  uninstall-service) shift; cmd_uninstall_service ;;
  setup-completions) shift; cmd_setup_completions ;;
  status)            shift; cmd_status "$@" ;;
  toggle-claude)     exec "$BIN_DIR/toggle-claude" ;;
  help|-h|--help)    show_help ;;
  *)                 error "Unknown command: $1"; show_help; exit 1 ;;
esac
