#!/usr/bin/env bash
#
# litellmctl — Thin shim that activates the venv and execs into Python.
#
# Tab completion support:
#   litellmctl --completions       (bash)
#   litellmctl --zsh-completions   (zsh)
#
set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$BIN_DIR/.." && pwd)"

# If running from a symlink outside ~/.litellm, resolve to canonical path
if [ ! -f "$PROJECT_DIR/config.yaml" ]; then
  PROJECT_DIR="$HOME/.litellm"
fi

VENV_DIR="$PROJECT_DIR/venv"

# Activate venv if it exists
if [ -d "$VENV_DIR" ]; then
  export VIRTUAL_ENV="$VENV_DIR"
  export PATH="$VENV_DIR/bin:$PATH"
fi

exec python3 -m lib "$@"
