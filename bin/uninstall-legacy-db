#!/usr/bin/env bash
# -----------------------------------------------------------------------------
# uninstall-legacy-db — Remove legacy LiteLLM PostgreSQL-related .env entries and
# stop/unregister the proxy service (launchd / systemd / nohup). Does NOT drop DBs.
#
# Usage:
#   ~/.litellm/bin/uninstall-legacy-db
#   LITELLM_HOME=/path/to/.litellm ~/.litellm/bin/uninstall-legacy-db
#   ~/.litellm/bin/uninstall-legacy-db /path/to/.litellm
#
# macOS: launchd LaunchAgent  com.litellm.proxy
# Linux: systemd user unit     litellm-proxy
# Any:   nohup + .proxy.pid if present
# -----------------------------------------------------------------------------
set -euo pipefail

PROJECT_DIR="${LITELLM_HOME:-${1:-$HOME/.litellm}}"
ENV_FILE="$PROJECT_DIR/.env"
PIDFILE="$PROJECT_DIR/.proxy.pid"
PORTFILE="$PROJECT_DIR/.proxy-port"

LAUNCHD_LABEL="com.litellm.proxy"
LAUNCHD_PLIST="${HOME}/Library/LaunchAgents/${LAUNCHD_LABEL}.plist"
SYSTEMD_UNIT="litellm-proxy"
SYSTEMD_FILE="${HOME}/.config/systemd/user/${SYSTEMD_UNIT}.service"

info()  { printf '\033[1;34m==>\033[0m %s\n' "$*"; }
warn()  { printf '\033[1;33m==>\033[0m %s\n' "$*" >&2; }
error() { printf '\033[1;31m==>\033[0m %s\n' "$*" >&2; exit 1; }

stop_proxy_launchd() {
  if ! command -v launchctl >/dev/null 2>&1; then
    warn "launchctl not found; skipping LaunchAgent."
    return 0
  fi
  info "Stopping LiteLLM proxy (launchd) ..."
  local uid
  uid="$(id -u)"
  launchctl bootout "gui/${uid}/${LAUNCHD_LABEL}" 2>/dev/null || true
  if [[ -f "$LAUNCHD_PLIST" ]]; then
    rm -f "$LAUNCHD_PLIST"
    info "Removed LaunchAgent: ${LAUNCHD_PLIST}"
  else
    info "No LaunchAgent plist found."
  fi
}

stop_proxy_systemd() {
  if ! command -v systemctl >/dev/null 2>&1; then
    warn "systemctl not found; skipping systemd user unit."
    return 0
  fi
  if [[ ! -f "$SYSTEMD_FILE" ]]; then
    info "No systemd user unit at ${SYSTEMD_FILE}."
    return 0
  fi
  info "Stopping LiteLLM proxy (systemd --user) ..."
  systemctl --user stop "$SYSTEMD_UNIT" 2>/dev/null || true
  systemctl --user disable "$SYSTEMD_UNIT" 2>/dev/null || true
  rm -f "$SYSTEMD_FILE"
  systemctl --user daemon-reload 2>/dev/null || true
  info "Removed systemd user unit: ${SYSTEMD_UNIT}"
}

stop_proxy_nohup() {
  if [[ ! -f "$PIDFILE" ]]; then
    return 0
  fi
  local pid
  pid="$(tr -d ' \n\r' < "$PIDFILE" || true)"
  if [[ -n "${pid:-}" ]] && [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
    info "Stopping background proxy (PID ${pid}) ..."
    kill "$pid" 2>/dev/null || true
    sleep 1
    if kill -0 "$pid" 2>/dev/null; then
      kill -9 "$pid" 2>/dev/null || true
    fi
  fi
  rm -f "$PIDFILE"
  info "Removed PID file."
}

stop_proxy() {
  case "$(uname -s)" in
    Darwin) stop_proxy_launchd ;;
    Linux)  stop_proxy_systemd ;;
    *)      warn "Unknown OS; only cleaning nohup PID file if present." ;;
  esac
  stop_proxy_nohup
  rm -f "$PORTFILE"
}

strip_legacy_db_env() {
  if [[ ! -f "$ENV_FILE" ]]; then
    warn "No .env at ${ENV_FILE} — skipping env cleanup."
    return 0
  fi
  info "Removing legacy PostgreSQL-related keys from .env ..."
  local tmp before after
  tmp="$(mktemp "${TMPDIR:-/tmp}/litellm-uninstall-env.XXXXXX")"
  before="$(wc -l < "$ENV_FILE" | tr -d ' ')"
  awk '!/^[[:space:]]*(DATABASE_URL|DISABLE_SCHEMA_UPDATE|STORE_MODEL_IN_DB|PROXY_BATCH_WRITE_AT|STORE_PROMPTS_IN_SPEND_LOGS)[[:space:]]*=/' "$ENV_FILE" > "$tmp"
  mv "$tmp" "$ENV_FILE"
  after="$(wc -l < "$ENV_FILE" | tr -d ' ')"
  if [[ "$before" -gt "$after" ]]; then
    info "Removed $((before - after)) line(s) from .env."
  else
    info "No legacy DB keys found in .env (already clean)."
  fi
}

main() {
  if [[ ! -d "$PROJECT_DIR" ]]; then
    error "Project directory not found: ${PROJECT_DIR} (set LITELLM_HOME or pass path as first argument)."
  fi

  info "LiteLLM legacy DB uninstall — LITELLM_HOME=${PROJECT_DIR}"
  stop_proxy
  strip_legacy_db_env

  echo ""
  info "PostgreSQL databases were not dropped. To remove a local DB named litellm:  dropdb litellm"
  info "Start the proxy again (without DB):  litellmctl start"
}

main "$@"
