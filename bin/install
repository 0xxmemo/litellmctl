#!/usr/bin/env bash
set -euo pipefail

BIN_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$BIN_DIR/.." && pwd)"
VENV_DIR="$PROJECT_DIR/venv"
SUBMODULE_DIR="$PROJECT_DIR/litellm"

# ── Helpers ──

info()  { printf "\033[1;34m==> %s\033[0m\n" "$*"; }
warn()  { printf "\033[1;33m==> %s\033[0m\n" "$*"; }
error() { printf "\033[1;31m==> %s\033[0m\n" "$*" >&2; }

is_interactive() { [ -t 0 ]; }

# Prevent git from blocking on credential/password prompts or opening a pager.
export GIT_TERMINAL_PROMPT=0
export GIT_PAGER=cat
export GIT_SSH_COMMAND="${GIT_SSH_COMMAND:-ssh -o BatchMode=yes -o ConnectTimeout=10}"

# Run a command with a hard timeout (GNU coreutils only).
# Sends SIGKILL 5s after SIGTERM in case the child ignores it.
run_with_timeout() {
  local secs="$1"; shift
  local bin
  bin="$(type -P timeout 2>/dev/null || true)"
  if [ -n "$bin" ]; then
    "$bin" -k 5 "$secs" "$@"
  else
    "$@"
  fi
}

# Check for local uncommitted changes, untracked files, or unpushed commits.
#
# Submodule drift (both directions):
# - In the **child** submodule: HEAD != parent's gitlink (fixed by submodule update).
# - In the **parent** repo: `git diff` shows `litellm | 2 +-` when the submodule
#   checkout does not match the parent's index/HEAD — even when `litellm/` is
#   clean inside. That is not user edits; use `--ignore-submodules=all` on diffs.
# Submodule checkout is aligned by sync_repo → submodule update, then
# normalize_submodule_ref.
has_local_changes() {
  local dir="$1"
  [ -d "$dir/.git" ] || [ -f "$dir/.git" ] || return 1
  # Staged changes (ignore submodule gitlink-only noise in parent repo)
  ! git -C "$dir" diff --cached --ignore-submodules=all --quiet 2>/dev/null && return 0
  # Unstaged changes
  ! git -C "$dir" diff --ignore-submodules=all --quiet 2>/dev/null && return 0
  # Untracked files
  [ -n "$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null)" ] && return 0
  # Unpushed commits (parent repo only; submodules follow parent-pinned SHA)
  if [ ! -f "$dir/.git" ]; then
    local ahead
    ahead=$(git -C "$dir" rev-list --count @{u}..HEAD 2>/dev/null || echo "0")
    [ "$ahead" -gt 0 ] && return 0
  fi
  return 1
}

# Unified sync handler for both parent repo and submodule.
#   sync_repo <dir> <label> [submodule]
# Pass "submodule" as $3 to use submodule update instead of git pull.
sync_repo() {
  local dir="$1" label="$2" mode="${3:-repo}"

  # ── Helper: pull or submodule-update ──
  _do_sync() {
    if [ "$mode" = "submodule" ]; then
      run_with_timeout 30  git -C "$PROJECT_DIR" submodule sync --recursive
      run_with_timeout 120 git -C "$PROJECT_DIR" submodule update --init --depth 1 --force litellm
    else
      run_with_timeout 60 git -C "$dir" pull --ff-only --no-recurse-submodules
    fi
  }

  # ── No changes → just sync ──
  if ! has_local_changes "$dir"; then
    info "Syncing $label ..."
    _do_sync || { error "Sync failed for $label."; exit 1; }
    return
  fi

  # ── Show what's dirty ──
  {
    echo ""
    warn "Local changes detected in $label:"
    git -C "$dir" --no-pager diff --stat 2>/dev/null || true
    git -C "$dir" --no-pager diff --cached --stat 2>/dev/null || true
    local untracked
    untracked=$(git -C "$dir" ls-files --others --exclude-standard 2>/dev/null | head -20)
    [ -n "$untracked" ] && info "Untracked files:" && echo "$untracked" | sed 's/^/    /'
    local ahead
    ahead=$(git -C "$dir" rev-list --count @{u}..HEAD 2>/dev/null || echo "0")
    [ "$ahead" -gt 0 ] && info "$ahead unpushed commit(s) ahead of remote"
    echo ""
  } >&2

  # ── Pick strategy (default: stash-sync-pop) ──
  local choice="stash"
  if is_interactive; then
    printf "  [L]ocal  [S]tash-sync-pop  [D]iscard  [l/S/d] " >&2
    read -r answer </dev/tty || answer=""
    case "$answer" in
      [lL]*) choice="local" ;;
      [dD]*) choice="discard" ;;
      *)     choice="stash" ;;
    esac
  else
    warn "Non-interactive — defaulting to stash-sync-pop." >&2
  fi

  case "$choice" in
    local)
      info "Using local $label as-is. Skipping sync."
      ;;

    stash)
      # Stash everything including untracked files
      info "Stashing $label changes ..."
      git -C "$dir" stash push --include-untracked --quiet 2>/dev/null \
        || git -C "$dir" stash --quiet 2>/dev/null \
        || { warn "Nothing to stash (unpushed commits only)."; }

      info "Syncing $label ..."
      _do_sync || { error "Sync failed for $label."; exit 1; }

      # Pop stash if there is one
      if git -C "$dir" stash list 2>/dev/null | grep -q .; then
        info "Restoring stashed $label changes ..."
        if ! git -C "$dir" stash pop --quiet 2>/dev/null; then
          warn "Stash pop had conflicts in $label."
          warn "Resolve manually, then run: git -C $dir stash drop"
        fi
      fi
      ;;

    discard)
      warn "Discarding all local $label changes."
      if [ "$mode" = "submodule" ]; then
        # For submodules: hard-reset to parent-expected commit, then let
        # submodule update re-checkout. This removes unpushed commits that
        # checkout/reset alone won't touch.
        local expected_sha
        expected_sha=$(git -C "$PROJECT_DIR" ls-tree HEAD -- litellm 2>/dev/null | awk '{print $3}')
        if [ -n "$expected_sha" ]; then
          git -C "$dir" reset --hard "$expected_sha" 2>/dev/null || true
        else
          git -C "$dir" reset --hard HEAD 2>/dev/null || true
        fi
      else
        # Reset tracked files (staged + unstaged)
        git -C "$dir" checkout -- . 2>/dev/null || true
        git -C "$dir" reset --quiet HEAD 2>/dev/null || true
      fi
      # Remove untracked files and directories
      git -C "$dir" clean -fd 2>/dev/null || true

      info "Syncing $label ..."
      _do_sync || { error "Sync failed for $label."; exit 1; }
      ;;
  esac
}

normalize_submodule_ref() {
  local dir="$1"
  [ -d "$dir/.git" ] || [ -f "$dir/.git" ] || return 0

  # Avoid changing branch state if user has local submodule edits.
  if has_local_changes "$dir"; then
    warn "Skipping submodule branch normalization (local changes detected)."
    return 0
  fi

  local head_sha
  head_sha=$(git -C "$dir" rev-parse HEAD 2>/dev/null || true)
  [ -n "$head_sha" ] || return 0

  # The parent repo determines the expected submodule commit.
  local expected_sha
  expected_sha=$(git -C "$PROJECT_DIR" ls-tree HEAD -- litellm 2>/dev/null | awk '{print $3}')
  [ -n "$expected_sha" ] || return 0

  # If HEAD doesn't match what the parent expects, force it.
  if [ "$head_sha" != "$expected_sha" ]; then
    git -C "$dir" reset --hard "$expected_sha" 2>/dev/null || true
    head_sha="$expected_sha"
  fi

  # Ensure local main branch points at the expected commit to avoid
  # "diverged" status between local main and origin/main.
  local current_branch
  current_branch="$(git -C "$dir" symbolic-ref -q --short HEAD 2>/dev/null || true)"

  if [ "$current_branch" != "main" ]; then
    # On detached HEAD — create or reset local main to expected commit and check it out
    if git -C "$dir" show-ref --verify --quiet refs/heads/main; then
      git -C "$dir" branch -f main "$expected_sha" 2>/dev/null || true
    fi
    git -C "$dir" checkout -q -B main "$expected_sha" 2>/dev/null || true
  else
    # Already on main — make sure it points at expected SHA
    local main_sha
    main_sha=$(git -C "$dir" rev-parse main 2>/dev/null || true)
    if [ "$main_sha" != "$expected_sha" ]; then
      git -C "$dir" reset --hard "$expected_sha" 2>/dev/null || true
    fi
  fi

  info "Submodule aligned to branch main (parent-pinned commit)."
}

# Minimum Python version. Upstream litellm now uses `match` statements and
# PEP 604 (X | Y) unions, both 3.10+ only.
PY_MIN_MAJOR=3
PY_MIN_MINOR=10

py_version_ge_min() {
  # Prints "True" if $1 (a python command) is >= PY_MIN_MAJOR.PY_MIN_MINOR
  "$1" -c "import sys; print(sys.version_info[:2] >= ($PY_MIN_MAJOR,$PY_MIN_MINOR))" 2>/dev/null || echo "False"
}

# Try newest first so we pick the best available interpreter. Fall back to
# generic python3/python last. Anything below 3.10 is rejected outright.
detect_python() {
  for cmd in python3.13 python3.12 python3.11 python3.10 python3 python; do
    if command -v "$cmd" &>/dev/null; then
      if [ "$(py_version_ge_min "$cmd")" = "True" ]; then
        echo "$cmd"
        return
      fi
    fi
  done

  warn "Python ${PY_MIN_MAJOR}.${PY_MIN_MINOR}+ not found." >&2
  local os_name
  os_name="$(uname -s)"

  # On macOS, attempt to install via Homebrew when available and
  # non-interactive auto-install is permitted (default: yes).
  if [ "$os_name" = "Darwin" ] && command -v brew &>/dev/null \
     && [ "${LITELLM_AUTO_INSTALL_PYTHON:-1}" = "1" ]; then
    info "Installing python@3.12 via Homebrew ..." >&2
    if brew install python@3.12 >&2; then
      if command -v python3.12 &>/dev/null \
         && [ "$(py_version_ge_min python3.12)" = "True" ]; then
        echo "python3.12"
        return
      fi
    fi
    warn "Homebrew install did not yield a usable python3.12." >&2
  fi

  error "Python ${PY_MIN_MAJOR}.${PY_MIN_MINOR}+ required. Install one of:" >&2
  case "$os_name" in
    Darwin) echo "  brew install python@3.12" >&2 ;;
    Linux)  echo "  sudo apt install python3.12 python3.12-venv  (Debian/Ubuntu)" >&2
            echo "  sudo dnf install python3.12                  (Fedora/RHEL)" >&2 ;;
  esac
  exit 1
}

# Returns "X.Y" for a given python command, or empty string on failure.
py_short_version() {
  "$1" -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null || true
}

# Returns "X.Y" of the venv's interpreter, or empty if the venv is missing
# / broken. Used to decide whether the venv must be rebuilt because the
# system interpreter changed (e.g. after a python version upgrade).
venv_short_version() {
  local venv_dir="$1"
  [ -x "$venv_dir/bin/python" ] || return 0
  py_short_version "$venv_dir/bin/python"
}

# Detect the system package manager on Linux.
pkg_install() {
  if command -v apt-get &>/dev/null; then
    sudo apt-get update -qq && sudo apt-get install -y -qq "$@"
  elif command -v dnf &>/dev/null; then
    sudo dnf install -y -q "$@"
  elif command -v yum &>/dev/null; then
    sudo yum install -y -q "$@"
  elif command -v pacman &>/dev/null; then
    sudo pacman -S --noconfirm --needed "$@"
  elif command -v apk &>/dev/null; then
    sudo apk add --quiet "$@"
  else
    error "No supported package manager found. Install manually: $*"
    return 1
  fi
}

# ── Platform checks ──

info "LiteLLM Proxy Installer (fork: 0xxmemo/litellm)"
echo ""

PYTHON="$(detect_python)"
PY_VERSION="$($PYTHON --version 2>&1)"
OS_NAME="$(uname -s)"
echo "  Platform: $OS_NAME (${OSTYPE:-unknown})"
echo "  Python:   $PY_VERSION ($PYTHON)"
echo ""

if [ "$OS_NAME" = "Linux" ]; then
  if ! $PYTHON -c "import venv" 2>/dev/null; then
    warn "python3-venv not found — installing ..."
    pkg_install python3-venv || true
  fi
  if ! $PYTHON -c "import ensurepip" 2>/dev/null; then
    warn "python3-pip/ensurepip not found — installing ..."
    pkg_install python3-pip || true
  fi
fi

# ── Parent repo sync ──

if [ -d "$PROJECT_DIR/.git" ]; then
  info "Checking parent repo ..."
  sync_repo "$PROJECT_DIR" "parent repo"

  # Wire repo-tracked git hooks (.githooks/) so post-checkout / post-merge /
  # post-rewrite auto-prune the litellm submodule. Idempotent.
  if [ -d "$PROJECT_DIR/.githooks" ]; then
    current_hooks="$(git -C "$PROJECT_DIR" config --get core.hooksPath 2>/dev/null || true)"
    if [ "$current_hooks" != ".githooks" ]; then
      git -C "$PROJECT_DIR" config core.hooksPath .githooks
      info "Configured git hooks path → .githooks"
    fi
  fi
fi

# ── Submodule ──

if [ ! -f "$SUBMODULE_DIR/pyproject.toml" ]; then
  info "Initializing litellm submodule ..."
  run_with_timeout 120 git -C "$PROJECT_DIR" submodule update --init --depth 1 litellm
  normalize_submodule_ref "$SUBMODULE_DIR"
else
  info "Checking litellm submodule ..."
  sync_repo "$SUBMODULE_DIR" "litellm submodule" submodule
  normalize_submodule_ref "$SUBMODULE_DIR"
fi

# ── Prune litellm submodule (strip docs/UI/CI bloat) ──
# Hooks handle the steady-state case; this catches first-run installs and
# any path that lands here without going through a hook (manual sync, etc).
if [ -x "$BIN_DIR/litellm-prune" ] && [ -d "$SUBMODULE_DIR" ]; then
  "$BIN_DIR/litellm-prune" || warn "Pruner failed (non-fatal)"
fi

# ── Virtualenv ──
#
# Rebuild triggers (in priority order):
#   1. LITELLM_REINSTALL_VENV=1  — explicit user override
#   2. venv exists but uses a Python older than $PY_MIN_MAJOR.$PY_MIN_MINOR
#      (e.g. left over from a 3.9 install before the upstream merge that
#      introduced `match` syntax)
#   3. venv exists but its Python X.Y differs from the chosen interpreter's
#      X.Y (system upgrade — old venv's stdlib still points at gone interpreter)

PY_NEW_VER="$(py_short_version "$PYTHON")"
VENV_VER="$(venv_short_version "$VENV_DIR")"
need_rebuild=0
rebuild_reason=""

if [ "${LITELLM_REINSTALL_VENV:-}" = "1" ]; then
  need_rebuild=1
  rebuild_reason="LITELLM_REINSTALL_VENV=1"
elif [ -n "$VENV_VER" ]; then
  if ! "$VENV_DIR/bin/python" -c "import sys; sys.exit(0 if sys.version_info[:2] >= ($PY_MIN_MAJOR,$PY_MIN_MINOR) else 1)" 2>/dev/null; then
    need_rebuild=1
    rebuild_reason="venv Python $VENV_VER < required $PY_MIN_MAJOR.$PY_MIN_MINOR"
  elif [ -n "$PY_NEW_VER" ] && [ "$VENV_VER" != "$PY_NEW_VER" ]; then
    need_rebuild=1
    rebuild_reason="venv Python $VENV_VER ≠ system Python $PY_NEW_VER"
  fi
fi

if [ -d "$VENV_DIR" ]; then
  if [ "$need_rebuild" = "1" ]; then
    warn "Rebuilding virtualenv ($rebuild_reason) ..."
    rm -rf "$VENV_DIR"
    $PYTHON -m venv "$VENV_DIR"
  else
    info "Reusing existing virtualenv (Python $VENV_VER)."
  fi
else
  info "Creating virtualenv at $VENV_DIR (Python $PY_NEW_VER) ..."
  $PYTHON -m venv "$VENV_DIR"
fi

# ── Activate ──

# shellcheck disable=SC1091
source "$VENV_DIR/bin/activate"

# ── Install dependencies ──

info "Upgrading pip ..."
pip install --upgrade pip --quiet

info "Installing litellm[proxy] (editable) ..."
pip install -e "$SUBMODULE_DIR[proxy]" --quiet
info "litellm installed."

info "Installing CLI dependencies (questionary, typer, rich) ..."
pip install --quiet questionary typer rich || warn "Some CLI deps failed to install"

info "Installing test dependencies (pytest) ..."
pip install --quiet pytest pytest-timeout || warn "Could not install pytest; tests will be unavailable"

# Prisma is required for DB migrations triggered by litellmctl start/restart/install.
# Keep this best-effort so non-DB setups still complete installation.
info "Ensuring prisma dependency for DB migrations ..."
if pip install --quiet prisma; then
  info "prisma installed."
else
  warn "Could not install prisma now; DB migrations may be skipped until fixed."
fi

# ── .env setup ──

if [ ! -f "$PROJECT_DIR/.env" ]; then
  if [ -f "$PROJECT_DIR/.env.example" ]; then
    cp "$PROJECT_DIR/.env.example" "$PROJECT_DIR/.env"
    sed -i.bak "s|/path/to/.litellm|$PROJECT_DIR|g" "$PROJECT_DIR/.env" 2>/dev/null || true
    rm -f "$PROJECT_DIR/.env.bak"
    warn "Created .env from template — edit to add your API keys"
  else
    warn "No .env file found. Copy the example and fill in your keys:"
    echo "  cp $PROJECT_DIR/.env.example $PROJECT_DIR/.env"
  fi
fi

# ── Sync auth file paths ──

"$BIN_DIR/litellmctl" init-env 2>/dev/null || true

# ── Shell completions ──

"$BIN_DIR/litellmctl" setup-completions 2>/dev/null || true

echo ""
info "Installation complete!"
echo ""
