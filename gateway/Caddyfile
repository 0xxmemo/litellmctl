# llm.0xmemo.com - LLM API Gateway
llm.0xmemo.com {
    # Proxy ALL dynamic routes to the Node backend
    handle /api/* {
        reverse_proxy localhost:3002
    }
    handle /auth {
        reverse_proxy localhost:3002
    }
    handle /auth/* {
        reverse_proxy localhost:3002
    }
    handle /dashboard {
        reverse_proxy localhost:3002
    }
    handle /dashboard/* {
        reverse_proxy localhost:3002
    }
    handle /admin {
        reverse_proxy localhost:3002
    }
    handle /v1/* {
        reverse_proxy localhost:3002
    }
    handle /health {
        reverse_proxy localhost:3002
    }
    handle / {
        reverse_proxy localhost:3002
    }
    handle /status {
        reverse_proxy localhost:3002
    }
    handle /messages {
        reverse_proxy localhost:3002
    }
    handle /messages/* {
        reverse_proxy localhost:3002
    }
    handle /keys {
        reverse_proxy localhost:3002
    }
    handle /settings {
        reverse_proxy localhost:3002
    }
    handle /analytics {
        reverse_proxy localhost:3002
    }
    handle /docs {
        reverse_proxy localhost:3002
    }
    handle /model/* {
        reverse_proxy localhost:3002
    }
    handle /global/* {
        reverse_proxy localhost:3002
    }

    # Static assets (JS/CSS built by Vite)
    handle /assets/* {
        root * /var/www/llm-gateway
        file_server
    }

    # Root-level static files (icons, manifest, etc.)
    # These must be served by Caddy directly — the Node backend returns empty body for binaries
    handle /*.png {
        root * /var/www/llm-gateway
        file_server
    }
    handle /*.ico {
        root * /var/www/llm-gateway
        file_server
    }
    handle /manifest.json {
        root * /var/www/llm-gateway
        file_server
    }

    tls 0xmemo@pm.me
}
