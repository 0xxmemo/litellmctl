# LLM API Gateway Configuration

# Server
PORT=14040
HOST=0.0.0.0
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017

# Session Secret (REQUIRED - min 32 characters for production)
SESSION_SECRET=your-secret-min-32-chars-change-in-production

# LiteLLM Proxy
LITELLM_URL=http://localhost:4040
# REQUIRED: LiteLLM master key — gateway uses this to authenticate ALL requests forwarded to LiteLLM.
# Without this, the gateway sends an empty Authorization header and LiteLLM rejects every request.
LITELLM_MASTER_KEY=sk-litellm-your-master-key-here

# Rate Limiting
RATE_LIMIT_DURATION=60
RATE_LIMIT_POINTS=100

# Security
BCRYPT_ROUNDS=12

# Admin Emails (comma-separated) - REQUIRED for admin access
ADMIN_EMAILS=admin@example.com

# CORS (optional, defaults to *)
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
