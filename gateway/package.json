{
  "name": "llm-api-gateway",
  "version": "1.2.1",
  "type": "module",
  "packageManager": "bun@1.3.9",
  "scripts": {
    "dev": "concurrently \"bun run --watch index.js\" \"vite\"",
    "dev:backend": "bun run --watch index.js",
    "dev:frontend": "vite",
    "start": "bun run index.js",
    "build": "vite build && cp dist/src/dashboard.html dist/index.html",
    "build:deploy": "vite build && cp dist/src/dashboard.html dist/index.html && cp -r dist/* /var/www/llm-gateway/ && sudo systemctl reload caddy",
    "deploy": "bash scripts/build-deploy.sh",
    "preview": "vite preview",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hono/node-server": "^1.19.9",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/router-devtools": "^1.163.2",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express-session": "^1.19.0",
    "framer-motion": "^12.34.3",
    "hono": "^4.12.3",
    "hono-rate-limiter": "^0.5.3",
    "hono-sess": "0.10.2",
    "jose": "^6.1.3",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "mongodb": "^7.1.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.20.0",
    "rate-limiter-flexible": "^9.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "module": "index.ts",
  "private": true
}
