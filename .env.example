# =============================================================================
# LiteLLM Proxy Configuration
# =============================================================================
LITELLM_MASTER_KEY=sk-litellm-change-me
LITELLM_LOCAL_MODEL_COST_MAP=true

# Anthropic Setup Token
ANTHROPIC_API_KEY=sk-ant-...

# Zai API Key
ZAI_API_KEY=your-zai-key

# Google AI API Key
GOOGLE_AI_API_KEY=your-google-ai-key

# Minimax API Key
MINIMAX_API_KEY=your-minimax-api-key

# DashScope key used by Alibaba Cloud Coding Plan routes
DASHSCOPE_API_KEY=sk-sp-your-coding-plan-key

# Proxy performance tuning
NUM_WORKERS=4
KEEPALIVE_TIMEOUT=120
AIOHTTP_CONNECTOR_LIMIT=500
AIOHTTP_CONNECTOR_LIMIT_PER_HOST=100
AIOHTTP_KEEPALIVE_TIMEOUT=120
AIOHTTP_TTL_DNS_CACHE=600

# Local inference servers
LOCAL_EMBEDDING_API_BASE=http://localhost:11434
LOCAL_TRANSCRIPTION_API_BASE=http://localhost:10300/v1

# SearXNG rotating proxy (applied on proxy start/restart)
# Comma-separated list of proxy URLs; SearXNG cycles through them to avoid rate limits
# SEARXNG_PROXIES=socks5h://127.0.0.1:9050,http://127.0.0.1:8118,socks5h://127.0.0.1:9052

# OAuth token directories
CHATGPT_TOKEN_DIR=/path/to/.litellm
CHATGPT_AUTH_FILE=auth.chatgpt.json
GEMINI_CLI_TOKEN_DIR=/path/to/.litellm
GEMINI_CLI_AUTH_FILE=auth.gemini_cli.json
QWEN_PORTAL_TOKEN_DIR=/path/to/.litellm
QWEN_PORTAL_AUTH_FILE=auth.qwen_portal.json
KIMI_CODE_TOKEN_DIR=/path/to/.litellm
KIMI_CODE_AUTH_FILE=auth.kimi_code.json

# =============================================================================
# LitellmCTL (dashboard UI) configuration
# =============================================================================

# Optional: FQDN that fronts the gateway behind Caddy. If set, install.sh
# generates a TLS-enabled Caddyfile for this host (Caddy handles Let's
# Encrypt issuance + renewal). Leave blank to serve plaintext :80 only.
# APP_DOMAIN=llm.example.com

# Server
GATEWAY_PORT=14041

# Container runtime (set automatically by the Dockerfile — do not set on VPC hosts).
# When LITELLM_HARNESS=docker, services run foreground under s6-overlay and the
# admin web console is enabled.
# LITELLM_HARNESS=docker
# GATEWAY_DATA_DIR=/data
# GATEWAY_CONSOLE_ENABLED=true

# SQLite database for session storage and usage tracking (optional override)
# Defaults to ~/.litellm/gateway/gateway.db if unset.
# GATEWAY_DB_PATH=/absolute/path/to/gateway.db

# Optional: path to a custom sqlite-vec extension build (vec0.{dylib,so})
# SQLITE_VEC_PATH=/opt/homebrew/lib/vec0

# Session secret (REQUIRED - min 32 characters for production)
GATEWAY_SESSION_SECRET=your-secret-min-32-chars-change-in-production

# Rate limiting
GATEWAY_RATE_LIMIT_DURATION=60
GATEWAY_RATE_LIMIT_POINTS=100

# Admin emails (comma-separated)
GATEWAY_ADMIN_EMAILS=admin@example.com

# ProtonMail SMTP for OTP emails via hydroxide bridge (optional)
# Run `litellmctl install --with-protonmail` to install hydroxide, then:
#   litellmctl protonmail auth   ← auto-authenticates using creds below
#   litellmctl protonmail start  ← starts the bridge on port 1025
# GATEWAY_PROTON_EMAIL=your-username@pm.me       # ProtonMail email (used as From address)
# GATEWAY_PROTON_USERNAME=your-username          # ProtonMail username (used for SMTP auth)
# GATEWAY_PROTON_PASSWORD=your-protonmail-pass   # ProtonMail account password (for `hydroxide auth`)
# GATEWAY_PROTON_2FA_SECRET=BASE32TOTPSECRET     # TOTP secret if 2FA enabled (from authenticator app)
# GATEWAY_PROTON_BRIDGE_PASS=                    # Auto-set by `litellmctl protonmail auth`
# GATEWAY_PROTON_SMTP_HOST=127.0.0.1
# GATEWAY_PROTON_SMTP_PORT=1025
