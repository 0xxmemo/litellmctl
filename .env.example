# LiteLLM Proxy Configuration
LITELLM_MASTER_KEY=sk-litellm-change-me
LITELLM_LOCAL_MODEL_COST_MAP=true

# Local PostgreSQL database for usage tracking, spend logs, and key management.
# Use 'litellmctl install' (or 'litellmctl install --with-db') to create the
# database and run migrations automatically.
DATABASE_URL=postgresql://localhost/litellm
# Keep startup fast/stable by skipping Prisma schema updates on every boot.
# If you need schema updates, run them manually then set this to false.
DISABLE_SCHEMA_UPDATE=true
# Usage-collection flags — written automatically by 'litellmctl install --with-db'.
# Remove these (or set to false) if you disable DB mode.
STORE_MODEL_IN_DB=true            # persist model/credential info in the DB
STORE_PROMPTS_IN_SPEND_LOGS=true  # store prompt + response content in spend logs
PROXY_BATCH_WRITE_AT=10           # batch-write spend logs every N seconds (default: 10)

# Anthropic — API key or OAT token
ANTHROPIC_API_KEY=sk-ant-...

# Z.AI
ZAI_API_KEY=your-zai-key

# Google AI (native Gemini API)
GOOGLE_AI_API_KEY=your-google-ai-key

# Qwen Portal (OAuth — run 'litellmctl auth qwen' to authenticate)
# No API key needed; tokens are managed via device-code OAuth flow.

# Kimi Code (OAuth — run 'litellmctl auth kimi' to authenticate)
# Requires Allegretto plan ($39/mo) or higher. Install kimi-cli first:
#   curl -LsSf https://code.kimi.com/install.sh | bash

# MiniMax (Anthropic-compatible endpoint)
MINIMAX_API_KEY=your-minimax-api-key

# Alibaba Cloud Coding Plan (OpenAI-compatible via coding-intl.dashscope.aliyuncs.com)
# Get your key at https://bailian.console.aliyun.com
DASHSCOPE_API_KEY=sk-sp-your-coding-plan-key

# Local inference servers (no auth required)
# Embedding — Ollama, LM Studio, Infinity, or any OpenAI-compatible /v1/embeddings
# Default: http://localhost:11434  (Ollama). Uncomment to override.
#LOCAL_EMBEDDING_API_BASE=http://localhost:11434
# Transcription — faster-whisper-server, whisper.cpp, or LocalAI
# Default: http://localhost:10300  (faster-whisper-server). Uncomment to override.
#LOCAL_TRANSCRIPTION_API_BASE=http://localhost:10300

# OAuth token directories (machine-specific, adjust per host)
# Run 'litellmctl init-env' to auto-fill these paths.
CHATGPT_TOKEN_DIR=/path/to/.litellm
CHATGPT_AUTH_FILE=auth.chatgpt.json
GEMINI_CLI_TOKEN_DIR=/path/to/.litellm
GEMINI_CLI_AUTH_FILE=auth.gemini_cli.json
QWEN_PORTAL_TOKEN_DIR=/path/to/.litellm
QWEN_PORTAL_AUTH_FILE=auth.qwen_portal.json
KIMI_CODE_TOKEN_DIR=/path/to/.litellm
KIMI_CODE_AUTH_FILE=auth.kimi_code.json
