# Keep the build context small + avoid baking secrets into the image.

# Secrets & local state
.env
.env.local
.gateway-secret
.proxy-port
.proxy.pid
auth.*.json

# SQLite (state lives on the /data volume)
**/*.db
**/*.db-shm
**/*.db-wal

# Build outputs + caches
**/node_modules/
**/.bun-cache/
gateway/dist/
venv/
**/__pycache__/
**/*.pyc
.pytest_cache/

# Logs
logs/
**/*.log

# Tooling scratch
ref/
.claude/
.vscode/
.idea/
*.bak
*.swp
.DS_Store

# Large checked-in reference material not needed in the image
config.yaml.bak
